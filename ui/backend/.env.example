# API keys for Bloomdow UI — copy to .env and fill in
# Keys here are used when "Use saved keys" is checked in the UI
# LiteLLM reads these by provider prefix

# REQUIRED for embeddings (Stage 2 diversity check uses text-embedding-3-small)
OPENAI_API_KEY=sk-...

# xAI Grok (fast, good for target + evaluator)
XAI_API_KEY=xai-...

# DeepSeek (cheap, good for target + evaluator)
DEEPSEEK_API_KEY=sk-...

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace (LiteLLM uses HF_TOKEN)
HF_TOKEN=hf_...

# AWS Bedrock (bearer token)
AWS_BEARER_TOKEN_BEDROCK=...
